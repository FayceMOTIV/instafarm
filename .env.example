# App
APP_ENV=development
SECRET_KEY=change_me_ultra_secure_key
ADMIN_TOKEN=your_super_admin_token

# Database
DATABASE_URL=sqlite+aiosqlite:///./instafarm.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Groq (gratuit jusqu'a 14400 req/jour)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Apify (scraping Instagram)
APIFY_TOKEN=apify_api_...
APIFY_ACTOR_HASHTAG=apify/instagram-hashtag-scraper
APIFY_ACTOR_PROFILE=apify/instagram-profile-scraper

# GrizzlySMS (creation comptes — remplace SMS-activate)
SMS_ACTIVATE_KEY=...
SMS_ACTIVATE_SERVICE=ig
SMS_PROVIDER=grizzlysms
SMS_API_URL=https://api.grizzlysms.com/stubs/handler_api.php

# HikerAPI (Phase 2 - remplace instagrapi en prod)
HIKERAPI_KEY=
HIKERAPI_ENDPOINT=https://api.hikerapi.com/v1

# CapSolver (resolution captcha — remplace 2captcha)
CAPSOLVER_KEY=CAP-...

# OCI Backup
OCI_BUCKET_NAME=instafarm-backup
OCI_NAMESPACE=...
OCI_REGION=eu-frankfurt-1

# Notifications Push (Web Push VAPID)
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_EMAIL=admin@instafarm.io

# Stripe (Phase 3)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# TikTok Pipeline — Voix
FISH_AUDIO_API_KEY=              # fish.audio -> API Keys (1h/mois gratuit)
ELEVENLABS_API_KEY=              # optionnel

# TikTok Pipeline — Images
PEXELS_API_KEY=                  # pexels.com/api (GRATUIT illimite)
UNSPLASH_ACCESS_KEY=             # unsplash.com/developers (50 req/h gratuit)

# TikTok Pipeline — Images IA
REPLICATE_API_KEY=              # replicate.com (Flux Schnell $0.003/img)

# TikTok Pipeline — Musique
PIXABAY_API_KEY=                # pixabay.com/api (gratuit)

# Alertes Telegram
TELEGRAM_BOT_TOKEN=             # @BotFather sur Telegram
TELEGRAM_CHAT_ID=               # Ton ID perso

# Creation comptes TikTok
FIVESIM_API_KEY=                # 5sim.net (~$0.01/numero)
SADCAPTCHA_API_KEY=             # sadcaptcha.com (~$0.002/captcha)

# Oracle VM
ORACLE_HOST=your.oracle.vm.ip
ORACLE_USER=ubuntu
